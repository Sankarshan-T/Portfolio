---
export const prerender = false;

import { db } from "@/db";
import { guestBook } from "@/db/schema";
import { desc } from "drizzle-orm";
import Terminal from "@/components/terminal.tsx";
import { User } from "@lucide/astro";

const entries = await db
    .select()
    .from(guestBook)
    .orderBy(desc(guestBook.createdAt));
---

<div class="w-full max-w-3xl flex flex-col items-center mx-auto gap-y-10 px-4">
    <div class="text-center max-w-xl flex flex-col items-center gap-y-2">
        <h1
            class="text-3xl sm:text-4xl font-bold text-blue-900 font-mono tracking-tight flex items-center gap-x-2"
        >
            <User class="size-8 text-blue-700 shrink-0" /> My guestbook
        </h1>
        <p class="text-sm text-blue-800/80 font-light px-4">
            Commit to guestbook.md from the terminal below!
        </p>
    </div>

    <Terminal client:load />

    <div class="w-full space-y-4">
        {
            entries.map((entry) => (
                <div class="flex gap-3">
                    <div class="flex flex-col items-center shrink-0">
                        <div class="mt-2 h-2.5 w-2.5 rounded-full bg-blue-700" />
                        <div class="h-full w-px bg-blue-900/50" />
                    </div>

                    <div class="flex-1 pb-4 min-w-0">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1">
                            <div class="flex items-baseline gap-2 flex-wrap">
                                <span class="font-semibold text-blue-950 break-words">
                                    {entry.name}
                                </span>

                                <span class="text-xs text-slate-700 shrink-0">
                                    committed
                                </span>
                            </div>

                            <span class="text-xs text-slate-800 sm:text-right">
                                {new Date(entry.createdAt).toLocaleDateString()}
                            </span>
                        </div>

                        <div class="mt-2 rounded-md border-2 border-blue-900 bg-blue-950/70 p-3 break-words">
                            <p class="whitespace-pre-wrap text-sm leading-relaxed text-slate-300">
                                {entry.message}
                            </p>

                            <div class="mt-2 flex items-center justify-between border-t-2 border-blue-900 pt-2 text-xs gap-2">
                                <span class="text-blue-400 truncate">
                                    commit{" "}
                                    {entry.id.toString(10).padStart(4, "0")}
                                </span>

                                <span class="text-white shrink-0">
                                    guestbook.md
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</div>
