---
import { Button } from "../ui/button";
import { Terminal, Milestone, Sparkles } from "@lucide/astro";
---

<div
    class="flex flex-col items-start justify-start gap-y-6 w-full max-w-5xl p-6 md:p-8"
>
    <div>
        <h1
            class="text-2xl sm:text-3xl font-mono font-bold text-blue-900 mb-2 tracking-tight"
        >
            Hi! I'm coolcream.
        </h1>
        <p class="text-blue-800 text-sm leading-relaxed max-w-2xl">
            I'm a full-stack developer focused on building web applications and
            UI designs. My coding journey started early and accelerated when I
            joined Hack Club.
        </p>
    </div>
    <div class="w-full flex flex-col gap-y-3">
        <h2
            class="text-xs font-mono uppercase tracking-wider text-blue-900/60 font-bold"
        >
            My Journey
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 w-full">
            <div
                class="flex flex-col p-3.5 bg-blue-200/40 border border-blue-400/40 rounded-xl hover:bg-blue-200/60 transition duration-200"
            >
                <span
                    class="flex items-center gap-x-1.5 text-xs font-mono font-bold text-blue-900 mb-1"
                >
                    <Terminal class="size-3.5 text-blue-600" /> Age 9
                </span>
                <p class="text-xs text-blue-800 leading-normal">
                    Started out making retro games in Scratch and Godot,
                    alongside basic Python scripts.
                </p>
            </div>

            <div
                class="flex flex-col p-3.5 bg-blue-200/40 border border-blue-400/40 rounded-xl hover:bg-blue-200/60 transition duration-200"
            >
                <span
                    class="flex items-center gap-x-1.5 text-xs font-mono font-bold text-blue-900 mb-1"
                >
                    <Milestone class="size-3.5 text-blue-600" /> Hack Club
                </span>
                <p class="text-xs text-blue-800 leading-normal">
                    Leveled up into full web dev, almost mastering React,
                    Next.js, UI designing, and backend basics.
                </p>
            </div>

            <div
                class="flex flex-col p-3.5 bg-blue-200/40 border border-blue-400/40 rounded-xl hover:bg-blue-200/60 transition duration-200"
            >
                <span
                    class="flex items-center gap-x-1.5 text-xs font-mono font-bold text-blue-900 mb-1"
                >
                    <Sparkles class="size-3.5 text-blue-600" /> Right Now
                </span>
                <p class="text-xs text-blue-800 leading-normal">
                    Exploring modern tools like Svelte, Astro, and Vite to build
                    cool stuff and learning backed structure.
                </p>
            </div>
        </div>
    </div>

    <div
        class="flex flex-col sm:flex-row items-center justify-start gap-3 mt-2 w-full"
    >
        <a href="#languages" class="w-full sm:w-auto">
            <Button className="py-4 text-xs font-mono w-full" variant="default">
                View My Stack
            </Button>
        </a>
        <a href="#projects" class="w-full sm:w-auto">
            <Button className="py-4 text-xs font-mono w-full" variant="outline">
                Explore Projects
            </Button>
        </a>
    </div>
</div>
