---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ExternalLink, CodeXml } from "@lucide/astro";

import projectdata from "@/lib/projects.json";

interface Project {
    title: string;
    description: string;
    tags: string[];
    githubUrl?: string;
    liveUrl?: string;
    featured?: boolean;
}

const projects = projectdata as Project[];
---

<BaseLayout>
    <div
        class="min-h-screen w-full flex items-start justify-start py-4 px-4 sm:px-6 md:py-4"
    >
        <div
            class="w-full h-full max-w-6xl mx-auto flex flex-col items-center gap-y-4"
        >
            <div
                class="text-left md:max-w-5xl max-w-xl w-full flex flex-col items-start gap-y-2"
            >
                <h1
                    class="text-2xl sm:text-3xl font-bold text-blue-900 font-mono tracking-tight flex items-center gap-x-3"
                >
                    <CodeXml class="size-9 text-blue-700 animate-pulse" /> My
                    projects
                </h1>
                <p
                    class="text-sm sm:text-base text-blue-800/80 font-light px-4"
                >
                    This page contains most of my projects
                </p>
            </div>

            <div
                class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:max-w-5xl"
            >
                {
                    projects.map((project) => (
                        <div class="bg-blue-100/40 backdrop-blur-xl border-2 border-blue-400 rounded-2xl shadow-md shadow-blue-400/30 p-6 flex flex-col justify-between hover:-translate-y-1.5 hover:shadow-xl hover:shadow-blue-400/50 transition-all duration-300 group">
                            <div>
                                <div class="flex items-start justify-between gap-x-2">
                                    <h3 class="text-lg font-bold font-mono text-blue-900 group-hover:text-blue-950 transition">
                                        {project.title}
                                    </h3>
                                    {project.featured && (
                                        <span class="text-[10px] uppercase tracking-wider bg-blue-500 text-white font-mono px-2 py-0.5 rounded-full border border-blue-600 shadow-sm shrink-0">
                                            Featured
                                        </span>
                                    )}
                                </div>

                                <p class="text-sm text-blue-800 font-light leading-relaxed">
                                    {project.description}
                                </p>
                            </div>

                            <div>
                                <div class="flex flex-wrap gap-1.5 mb-4">
                                    {project.tags.map((tag) => (
                                        <span class="text-xs font-mono bg-blue-200/60 text-blue-900 px-2 py-0.5 rounded-md border border-blue-300/40">
                                            {tag}
                                        </span>
                                    ))}
                                </div>

                                <div class="flex items-center gap-x-4 pt-3 border-t border-blue-300/30">
                                    {project.githubUrl && (
                                        <a
                                            href={project.githubUrl}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="flex items-center gap-x-1.5 text-xs font-mono text-blue-700 hover:text-blue-900 transition"
                                        >
                                            <CodeXml class="size-4" /> Source
                                            Code
                                        </a>
                                    )}
                                    {project.liveUrl && (
                                        <a
                                            href={project.liveUrl}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="flex items-center gap-x-1.5 text-xs font-mono text-blue-700 hover:text-blue-900 transition ml-auto"
                                        >
                                            <ExternalLink class="size-4" /> Live
                                            Demo
                                        </a>
                                    )}
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</BaseLayout>
