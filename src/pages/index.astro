---
import { Button } from "@/components/ui/button";
import BaseLayout from "../layouts/BaseLayout.astro";
import About from "@/components/about.astro";
---

<BaseLayout>
	<div class="h-screen w-full flex items-center justify-center">
		<div class="flex flex-col items-center justify-start gap-y-3">
			<p class="text-6xl font-semibold tracking-wider leading-none">
				Hey! I'm <span class="text-coolcream font-bold">coolcream</span
				>,
			</p>
			<p class="text-2xl tracking-wide font-light">
				an overly dedicated software developer
			</p>
			<a href="#about">
				<Button size="lg"> Read more! </Button>
			</a>
		</div>
	</div>
	<section id="about">
		<About />
	</section>
</BaseLayout>

<style>
	.text-coolcream {
		background: linear-gradient(
			90deg,
			rgba(41, 58, 143, 1) 36%,
			rgba(184, 0, 0, 1) 88%
		);

		-webkit-background-clip: text;
		background-clip: text;

		-webkit-text-fill-color: transparent;
		color: transparent;

		font-weight: bold;
	}
</style>
